# Define supported bases
BASE_MAP = {
    "-x": 16,
    "--hex": 16,
    "-d": 10,
    "--decimal": 10,
    "-o": 8,
    "--octal": 8,
    "-b": 2,
    "--binary": 2,
}

# Define colors for each base
