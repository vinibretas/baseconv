# Define base names and prefixes
BASES = [(16, "cyan"), (10, "green"), (8, "yellow"), (2, "magenta")]
PREFIXES = {16: "0x", 10: "  ", 8: "0o", 2: "0b"}
BASE_NAMES = {16: "Hex", 10: "Dec", 8: "Oct", 2: "Bin"}


def is_valid_number(number: str, base: int) -> bool:
    try:
        int(number, base)
        return True
    except ValueError:
        return False


###  def convert_and_print(number: str, input_base: int, is_bold=False):
def convert_and_print(number: str, input_base: int, is_bold=False, output_bases=None):
    if not is_valid_number(number, input_base):
        console.print(
            f"[bold red]Error:[/] '{number}' is not a valid number in base {input_base}."
        )
        ####  sys.exit(1)
        return

    decimal_value = int(number, input_base)
    for base, color in BASES:
        if output_bases and base not in output_bases:
            continue
        prefix = PREFIXES[base]
        prefix = PREFIXES[base]
        base_name = BASE_NAMES[base]
        formatted_value = {
            16: f"{decimal_value:X}",
            10: f"{decimal_value}",
            8: f"{oct(decimal_value)[2:]}",
            2: f"{bin(decimal_value)[2:]}",
        }[base]

        style = f"bold {color}" if base == input_base and is_bold else color

        # Build our final output line
        output_line = f"{base_name}: [red]{prefix}[/][{style}]{formatted_value}[/]"

        # If base 2, also show grouped bits in parentheses
        if base == 2:
            bin_value = formatted_value
            remainder = len(bin_value) % 4
            if remainder != 0:
                bin_value = ("0" * (4 - remainder)) + bin_value
            groups = [bin_value[i : i + 4] for i in range(0, len(bin_value), 4)]
            grouped = " ".join(groups)
            output_line += f" ([bold]{grouped}[/])"

        console.print(output_line)


